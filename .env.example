# Required — Anthropic API key for Claude (claude-sonnet-4-6)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required for real SERP data — not needed when use_mock=true in job requests
SERPAPI_KEY=your-serpapi-key-here

# Optional — LangSmith observability (https://smith.langchain.com)
# Set LANGCHAIN_TRACING_V2=true to enable. Requires LANGCHAIN_API_KEY.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=seo-article-generator
